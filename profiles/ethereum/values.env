# chainviz Ethereum プロファイル — genesis 生成設定
#
# ethpandaops/ethereum-genesis-generator に渡す環境変数。
# このファイルが「genesis 設定ファイル」の実体であり、ここから
# EL(reth)用 genesis.json と CL(lighthouse)用 genesis.ssz / config.yaml が
# 生成される。genesis.json / genesis.ssz は生成時刻を埋め込むため、
# 静的ファイルとしてコミットせず初回起動時に生成し、以降は共有ボリューム上の
# 生成物を再利用する(冪等。詳細は README.md「genesis の扱い」を参照)。
#
# 生成に使う変数の一覧・既定値は generator イメージの
# /defaults/defaults.env にある。ここでは chainviz 用に絞った値だけ上書きする。

# --- ネットワーク基本設定 ---
export PRESET_BASE="mainnet"
export CHAIN_ID="1337"

# --- バリデーター最小構成 ---
# 本番の 1 エポック=32 スロット構成を保ちつつ、検証に必要な最小限の
# バリデーター数に絞る。64 なら 2 ノードに分割しても各ノードが
# 十分な議決権を持ち、確実に finality に到達する。
export NUMBER_OF_VALIDATORS="64"

# NODE_COUNT はこのプロファイル独自の変数(generator 標準ではない)。
# generate-genesis.sh がバリデーター鍵を何ノード分に分割するかを決める。
# docker-compose.yml のノード数と一致させること。
export NODE_COUNT="2"

# --- slot time(mainnet と同じ 12 秒) ---
# 一時期 2 秒に短縮していたが、学習アプリとして「非現実的な周期のチェーンを
# 見せる」ことが誤解を招くという判断から mainnet と同じ 12 秒に戻した
# (Issue #322)。値を変更した場合、genesis 生成物(config.yaml 等)に
# 焼き込まれるため、稼働中の既存環境では `docker compose down -v` で
# 共有ボリュームごと作り直す必要がある(README.md 参照)。
export SLOT_DURATION_IN_SECONDS="12"
export SLOT_DURATION_MS="12000"
export SECONDS_PER_ETH1_BLOCK="12"

# --- genesis までの猶予 ---
# 生成完了〜全ノード起動までの余裕。genesis 時刻 = 生成時刻 + この秒数。
export GENESIS_DELAY="20"

# --- フォークスケジュール ---
# genesis 時点で Electra(Prague)まで有効化。実験的な Fulu(PeerDAS)以降は
# 無効(遠い将来)にして、reth/lighthouse が安定サポートする範囲に収める。
export DENEB_FORK_EPOCH="0"
export ELECTRA_FORK_EPOCH="0"
export FULU_FORK_EPOCH="18446744073709551615"

# --- mnemonic(genesis とワークベンチで共有する単一の出所)---
# EL/CL のバリデーター鍵導出・EL プリマインアカウント生成に使う mnemonic。
# generator イメージの /defaults/defaults.env にも同名の既定値があるが、
# それに暗黙依存するとイメージ更新で既定値が変わったときにプリマイン
# アカウントとワークベンチの鍵が静かに食い違う。値をここで明示的に
# 固定し、mnemonic の出所をこのファイル1箇所に一本化する。
# docker-compose.yml のワークベンチもこのファイルを env_file で読み込み、
# 同じ mnemonic を参照する(cast --mnemonic "$EL_AND_CL_MNEMONIC")。
export EL_AND_CL_MNEMONIC="sleep moment list remain like wall lake industry canvas wonder ecology elite duck salad naive syrup frame brass utility club odor country obey pudding"

# --- EL プリマイン ---
# ワークベンチ(Foundry)から tx を送るための残高付きアカウントを
# 上記 mnemonic から 8 個生成する。導出パスは foundry 既定
# (m/44'/60'/0'/0/N)と同じなので、cast --mnemonic "$EL_AND_CL_MNEMONIC" で
# 同じ鍵を使える。
export EL_PREMINE_COUNT="8"
